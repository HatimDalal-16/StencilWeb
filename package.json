{
  "name": "buttondesignsystem",
  "version": "0.0.1",
  "description": "Stencil Component Starter",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/buttondesignsystem/buttondesignsystem.esm.js",
  "exports": {
    ".": {
      "import": "./dist/buttondesignsystem/buttondesignsystem.esm.js",
      "require": "./dist/buttondesignsystem/buttondesignsystem.cjs.js"
    },
    "./my-component": {
      "import": "./dist/components/my-component.js",
      "types": "./dist/components/my-component.d.ts"
    },
    "./loader": {
      "import": "./loader/index.js",
      "require": "./loader/index.cjs",
      "types": "./loader/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stenciljs/component-starter.git"
  },
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "build": "stencil build",
    "start": "stencil build --dev --watch --serve",
    "test": "stencil-test",
    "test:watch": "stencil-test --watch",
    "generate": "stencil generate",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build",
    "dev": "stencil build && concurrently \"npm run start\" \"npm run storybook\""
  },
  "devDependencies": {
    "@stencil-community/postcss": "^2.2.0",
    "@stencil/core": "^4.27.1",
    "@stencil/vitest": "^1.8.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/web-components-vite": "^10.3.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.13.5",
    "@vitest/browser-playwright": "^4.0.0",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.8",
    "storybook": "^10.3.3",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.8.1",
    "vitest": "^4.0.0"
  },
  "license": "MIT"
}
